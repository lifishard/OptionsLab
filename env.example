# ── OptionsLab · Environment variables ─────────────────────────
# Copy this file to `.env` for local dev.
# On Railway, set these in Project → Variables (do NOT commit .env).

# Postgres connection string. On Railway, add a Postgres plugin and use
# ${{ Postgres.DATABASE_URL }}. For Supabase, use the pooler URL (port 6543).
DATABASE_URL=postgresql://postgres:password@localhost:5432/optionslab

NODE_ENV=production

# Any random string. Not currently required for core features.
SESSION_SECRET=change-me

# ── Yahoo 限流节流（分组 + 延迟批量下载）─────────────────────
# 全部有默认值，不设也能跑。收到 429 就把 MIN_GAP 调大、GROUP_COUNT 调大。

# 全局闸门：两次 Yahoo 调用之间的最小平均间隔（ms）。6000 → 上限 600 次/小时
YAHOO_MIN_GAP_MS=6000
# 令牌桶容量：用户首次打开期权链允许的突发次数（避免逐个等 6 秒）
YAHOO_BURST=8
# 后台任务放行门槛：桶里至少剩这么多令牌才让后台跑，保证用户优先
YAHOO_BG_RESERVE=5
# 每次调用后的随机抖动上限（ms），打散规律性指纹
YAHOO_JITTER_MS=1200
# 命中 429 后的初始冷却 / 最大冷却（ms），指数翻倍
YAHOO_BASE_BACKOFF_MS=60000
YAHOO_MAX_BACKOFF_MS=900000

# 每个 symbol 抓几个到期日 → 调用次数 = 1 + 这个值。4 → 5 次/symbol
CHAIN_MAX_EXPIRIES=4
# 白名单分几组轮询；每 tick 只刷一组
CHAIN_GROUP_COUNT=5
# tick 间隔（ms）。5 组 × 15min → 每只 75 分钟刷一次
CHAIN_REFRESH_MS=900000
# 同组内 symbol 之间的错峰间隔（ms）
CHAIN_JITTER_MS=45000
# 内存缓存 TTL / Postgres 视为过期的阈值（ms）
CHAIN_MEM_TTL_MS=1800000
CHAIN_STALE_MS=5400000
# 只在美东 09:00–16:30 工作日刷新（省约 70% 流量）。设 false 则全天刷
CHAIN_MARKET_HOURS_ONLY=true
# 启动时预热几组（0 = 完全不预热，最省）
CHAIN_WARMUP_ON_BOOT=true
CHAIN_WARMUP_GROUPS=1
